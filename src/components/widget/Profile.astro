---
import { Icon } from "astro-icon/components";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import { profileConfig } from "@/config/profileConfig";
import { url } from "@/utils/url-utils";
---

<div class="card-base p-3">
  <a
    aria-label="Go to About Page"
    href={url("/about/")}
    class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-48 lg:max-w-none overflow-hidden rounded-xl active:scale-95"
  >
    <div
      class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center"
    >
      <Icon is:inline
        name="fa7-regular:address-card"
        class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
      />
    </div>
    <ImageWrapper
      src={profileConfig.avatar || ""}
      alt="Profile Image of the Author"
      class="mx-auto lg:w-full h-full lg:mt-0"
      loading="eager"
      fetchpriority="high"
      widths={[350]}
      sizes="350px"
    />
  </a>
  <div class="px-2">
    <div
      class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition"
    >
      {profileConfig.name}
    </div>
    <div
      class="h-1 w-5 bg-(--primary) mx-auto rounded-full mb-2 transition"
    >
    </div>
    <div class="text-center text-neutral-400 mb-2.5 transition">
      {profileConfig.bio}
    </div>
    <div class="flex flex-wrap gap-2 justify-center mb-1">
      {profileConfig.links.map(item => {
        const showName = item.showName;
        const className = showName
          ? "btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
          : "btn-regular rounded-lg h-10 w-10 active:scale-90";

        // 有 popupText 的链接：渲染为按钮，点击弹窗显示文本
        if (item.popupText) {
          return (
            <button
              type="button"
              aria-label={item.name}
              class={className}
              data-popup-text={item.popupText}
              data-popup-copy-text={item.popupCopyText || item.popupText}
            >
              <Icon is:inline name={item.icon} class="text-[1.5rem]"></Icon>
              {showName && item.name}
            </button>
          );
        }

        // 普通链接
        if (item.url?.startsWith("mailto:")) {
          const encodedEmail = Buffer.from(item.url.replace("mailto:", "")).toString("base64");
          return (
            <a rel="me" aria-label={item.name} href="#" data-encoded-email={encodedEmail} class={className}>
              <Icon is:inline name={item.icon} class="text-[1.5rem]"></Icon>
              {showName && item.name}
            </a>
          );
        }

        if (!item.url) {
          return (
            <span aria-label={item.name} class={className}>
              <Icon is:inline name={item.icon} class="text-[1.5rem]"></Icon>
              {showName && item.name}
            </span>
          );
        }
        return (
          <a rel="me" aria-label={item.name} href={item.url} target="_blank" class={className}>
            <Icon is:inline name={item.icon} class="text-[1.5rem]"></Icon>
            {showName && item.name}
          </a>
        );
      })}
    </div>
  </div>
</div>

<script>
  function initProfilePopup() {
    // 避免 Swup 重复初始化时创建多个弹窗
    if (document.getElementById("profile-popup")) return;

    // 动态创建弹窗并注入到 body，确保 fixed 定位相对于视口
    const popup = document.createElement("div");
    popup.id = "profile-popup";
    popup.className = "profile-popup-hidden";
    popup.innerHTML = `
      <div id="profile-popup-backdrop" class="profile-popup-backdrop"></div>
      <div class="profile-popup-card">
        <p id="profile-popup-text" class="profile-popup-text"></p>
        <div class="profile-popup-actions">
          <button id="profile-popup-copy" class="btn-regular profile-popup-btn">
            <span class="profile-popup-copy-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </span>
            <span>复制</span>
          </button>
          <button id="profile-popup-close" class="btn-primary profile-popup-btn">关闭</button>
        </div>
      </div>
    `;
    document.body.appendChild(popup);

    const popupText = document.getElementById("profile-popup-text");
    const popupCopy = document.getElementById("profile-popup-copy");
    const popupCopySpan = popupCopy?.querySelector("span:last-child") as HTMLSpanElement | null;
    const popupClose = document.getElementById("profile-popup-close");
    const popupBackdrop = document.getElementById("profile-popup-backdrop");
    if (!popup || !popupText) return;

    let currentCopyText = "";
    let copyTimeoutId: number | null = null;

    function showPopup(displayText: string, copyText: string) {
      currentCopyText = copyText;
      if (popupText) popupText.textContent = displayText;
      // 重置复制按钮文字
      if (copyTimeoutId !== null) {
        clearTimeout(copyTimeoutId);
        copyTimeoutId = null;
      }
      if (popupCopySpan) popupCopySpan.textContent = "复制";
      popup.classList.remove("profile-popup-hidden");
      popup.classList.add("profile-popup-visible");
    }

    function hidePopup() {
      popup.classList.remove("profile-popup-visible");
      popup.classList.add("profile-popup-hidden");
    }

    // 委托点击事件：所有带 data-popup-text 的按钮
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest("[data-popup-text]") as HTMLElement | null;
      if (btn) {
        e.preventDefault();
        e.stopPropagation();
        const displayText = btn.getAttribute("data-popup-text") || "";
        const copyText = btn.getAttribute("data-popup-copy-text") || displayText;
        showPopup(displayText, copyText);
      }
    });

    // 关闭按钮
    popupClose?.addEventListener("click", hidePopup);
    popupBackdrop?.addEventListener("click", hidePopup);

    // 复制按钮
    popupCopy?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(currentCopyText);
        if (popupCopySpan) {
          popupCopySpan.textContent = "已复制";
          if (copyTimeoutId !== null) clearTimeout(copyTimeoutId);
          copyTimeoutId = window.setTimeout(() => {
            if (popupCopySpan) popupCopySpan.textContent = "复制";
            copyTimeoutId = null;
          }, 1500);
        }
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = currentCopyText;
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      }
    });

    // ESC 关闭
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && popup.classList.contains("profile-popup-visible")) {
        hidePopup();
      }
    });

    // 处理 mailto 反爬虫
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const mailLink = target.closest("[data-encoded-email]") as HTMLElement | null;
      if (mailLink) {
        e.preventDefault();
        const encodedEmail = mailLink.getAttribute("data-encoded-email");
        if (encodedEmail) {
          const decodedEmail = atob(encodedEmail);
          window.location.href = "mailto:" + decodedEmail;
        }
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProfilePopup);
  } else {
    initProfilePopup();
  }

  // Swup 页面切换后重新初始化（已有弹窗则跳过）
  document.addEventListener("swup:contentReplaced", initProfilePopup);
  document.addEventListener("swup:content:replace", initProfilePopup);
  document.addEventListener("swup:page:view", initProfilePopup);
</script>

<style is:global>
  #profile-popup {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }
  #profile-popup.profile-popup-hidden {
    opacity: 0;
    pointer-events: none;
  }
  #profile-popup.profile-popup-hidden .profile-popup-card {
    transform: scale(0.9);
  }
  #profile-popup.profile-popup-visible {
    opacity: 1;
    pointer-events: auto;
  }
  #profile-popup.profile-popup-visible .profile-popup-card {
    transform: scale(1);
  }

  .profile-popup-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .profile-popup-card {
    position: relative;
    background: var(--card-bg);
    border-radius: 1rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    padding: 1.5rem;
    margin: 0 1rem;
    max-width: 18rem;
    width: 100%;
    z-index: 10;
    transition: transform 0.2s ease;
  }

  .profile-popup-text {
    text-align: center;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    word-break: break-all;
    user-select: all;
  }

  .profile-popup-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .profile-popup-btn {
    border-radius: 0.5rem;
    height: 2.25rem;
    padding: 0 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .profile-popup-btn:active {
    transform: scale(0.95);
  }

  .profile-popup-copy-icon {
    display: flex;
    align-items: center;
  }
</style>
